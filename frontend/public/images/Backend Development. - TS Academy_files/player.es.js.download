      }

      :host([${ee.USER_INACTIVE}]:not([${ee.NO_AUTOHIDE}]):not([${y.MEDIA_PAUSED}]):not([${y.MEDIA_IS_CASTING}]):not([${ee.AUDIO}])) ::slotted([slot=media]) {
