\u03CC\u03B3\u03C1\u03B1\u03BC\u03BC\u03B1 \u03C0\u03B5\u03C1\u03B9\u03AE\u03B3\u03B7\u03C3\u03AE\u03C2 \u03C3\u03B1\u03C2 \u03B4\u03B5\u03BD \u03C5\u03C0\u03BF\u03C3\u03C4\u03B7\u03C1\u03AF\u03B6\u03B5\u03B9 \u03B1\u03C5\u03C4\u03AE \u03C4\u03B7 \u03BC\u03BF\u03C1\u03C6\u03AE.","An unsupported error occurred. The server or network failed, or your browser does not support this format.":"\u03A0\u03C1\u03BF\u03AD\u03BA\u03C5\u03C8\u03B5 \u03BC\u03B7 \u03C5\u03C0\u03BF\u03C3\u03C4\u03B7\u03C1\u03B9\u03B6\u03CC\u03BC\u03B5\u03BD\u03BF \u03C3\u03C6\u03AC\u03BB\u03BC\u03B1. \u039F \u03B4\u03B9\u03B1\u03BA\u03BF\u03BC\u03B9\u03C3\u03C4\u03AE\u03C2 \u03AE \u03C4\u03BF \u03B4\u03AF\u03BA\u03C4\u03C5\u03BF \u03B1\u03C0\u03AD\u03C4\u03C5\u03C7\u03B5, \u03AE \u03C4\u03BF \u03C0\u03C1\u03CC\u03B3\u03C1\u03B1\u03BC\u03BC\u03B1 \u03C0\u03B5\u03C1\u03B9\u03AE\u03B3\u03B7\u03C3\u03AE\u03C2 \u03C3\u03B1\u03C2 \u03B4\u03B5\u03BD \u03C5\u03C0\u03BF\u03C3\u03C4\u03B7\u03C1\u03AF\u03B6\u03B5\u03B9 \u03B1\u03C5\u03C4\u03AE \u03C4\u03B7 \u03BC\u03BF\u03C1\u03C6\u03AE.","The media is encrypted and there are no keys to decrypt it.":"\u03A4\u03BF \u03C0\u03BF\u03BB\u03C5\u03BC\u03AD\u03C3\u03BF \u03B5\u03AF\u03BD\u03B1\u03B9 \u03BA\u03C1\u03C5\u03C0\u03C4\u03BF\u03B3\u03C1\u03B1\u03C6\u03B7\u03BC\u03AD\u03BD\u03BF \u03BA\u03B1\u03B9 \u03B4\u03B5\u03BD \u03C5\u03C0\u03AC\u03C1\u03C7\u03BF\u03C5\u03BD \u03BA\u03BB\u03B5\u03B9\u03B4\u03B9\u03AC \u03B3\u03B9\u03B1 \u03C4\u03B7\u03BD \u03B1\u03C0\u03BF\u03BA\u03C1\u03C5\u03C0\u03C4\u03BF\u03B3\u03C1\u03AC\u03C6\u03B7\u03C3\u03AE \u03C4\u03BF\u03C5."};var Kb={"Start airplay":"K\xE4ynnist\xE4 AirPlay","Stop airplay":"Lopeta AirPlay",Audio:"\xC4\xE4ni",Captions:"Tekstitykset","Enable captions":"Tekstitys p\xE4\xE4lle","Disable captions":"Poista tekstitys","Start casting":"Aloita suoratoisto","Stop casting":"Lopeta suoratoisto","Enter fullscreen mode":"Siirry kokokuvaan","Exit fullscreen mode":"Poistu kokokuvasta",Mute:"Mykist\xE4",Unmute:"Poista myki